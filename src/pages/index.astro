<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<!-- Google Fonts -->
		 <link rel="preconnect" href="https://fonts.googleapis.com">
		 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		 <link href="https://fonts.googleapis.com/css2?family=Domine:wght@400..700&display=swap" rel="stylesheet">
		<!-- Google Fonts -->

		<!-- Global Styles -->
		 <link rel="preconnect" href="assets/global.css" />
		 <link rel="stylesheet" href="assets/global.css" />
		<!-- Global Styles -->

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<style>
            :root{
                --ink: #3A2E2B;
                --parchment: #F8EEE5;
                --rose: #C9808F;
                --rose-deep: #93425A;
                --rose-line: #D9AEB6;
                --gold: #B9946A;
            }

            *{
                border: none;
                box-sizing: border-box;
                padding: 0;
                margin: 0;

                font-family: "Domine", serif;
                font-optical-sizing: auto;
                font-weight: 400;
                font-style: normal;

                color: var(--ink);
                text-decoration: none;
            }

            li{ display: block; }

            body{
                background: var(--parchment);

                min-height: 100vh;
                width: 100%;

                display: flex;
                justify-content: center;
                align-items: center;
                padding: 1.5rem;
            }

            h1{
                font-size: clamp(1.8rem, 6vw, 4rem);
                text-align: center;
                line-height: 1.15;
            }

            h1, ul{
                margin-block: 1.2rem;
            }

            strong{ font-weight: 600; }

            a:hover{
                color: var(--rose-deep);
                text-decoration: underline;
                text-underline-offset: 0.6rem;
            }

            #titles{
                color: var(--gold);
                text-align: center;
            }

            #social{
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                align-items: center;
                gap: 0.5rem 2rem;

                text-transform: uppercase;
                font-size: clamp(0.75rem, 1.6vw, 0.95rem);

                width: 100%;
            }

            #legal *, #copy{
                font-size: 0.65rem;
                text-align: center;
            }

            #legal{ margin-top: 2.5rem; }

            #copy{
                margin-top: 1.5rem;
                margin-bottom: 0;
            }

            .bordered-container{
                border: 1px solid var(--rose-line);
                padding: clamp(1rem, 3vw, 2rem);
                width: 100%;
                max-width: 1280px;
            }

            .divider{
                display: flex;
                align-items: center;
                gap: 12px;

                margin-block: 3rem;
                margin-inline: clamp(1rem, 8vw, 4rem);
            }

            .divider .rule{
                flex: 1;
                height: 1px;
                background: var(--rose-line);
            }

            .divider .mark{
                width: 8px;
                height: 8px;
                border: 2px solid var(--rose-line);
                transform: rotate(45deg);
                flex-shrink: 0;
            }
		</style>

		<title>Luiza M. S. Calderon</title>
	</head>
	<body>
		<div class="bordered-container" style="border-width: 2px; padding: clamp(0.5rem, 3vw, 1rem);">
            <div class="bordered-container">
                <h1>Luiza M. S. Calderon</h1>
                <ul id="titles">
                    <li>Fonoaudióloga (Crfª2-23919)</li>
                    <li>Mestranda em Ciências da Saúde e Comunicação Humana (Unesp - Marília/SP)</li>
                </ul>
                <div class="divider">
                    <span class="rule"></span>
                    <span class="mark"></span>
                    <span class="rule"></span>
                </div>
                <ul id="social">
                    <li>
                        <a 
                            href="https://instagram.com/luizacalderon.fono" 
                            target="_blank" rel="noopener noreferrer"
                        >Instagram</a>
                    </li>
                    <li>
                        <a 
                            href="https://lattes.cnpq.br/3093458116906395" 
                            target="_blank" rel="noopener noreferrer"
                        >Lattes</a>
                    </li>
                    <li>
                        <a 
                            href="mailto:luizacalderon.fono@gmail.com" 
                            target="_blank" rel="noopener noreferrer"
                        >luizacalderon.fono@gmail.com</a>
                    </li>
                </ul>
                <ul id="legal">
                    <li><strong>Luiza Martins da Silveira Calderon</strong></li>
                    <li><strong>60.298.663/0001-66</strong></li>
                    <li>Marília - São Paulo</li>
                </ul>
                <p id="copy"><small>2026 &copy; Todos os direitos reservados.</small></p>
            </div>
        </div>
	</body>
</html>
